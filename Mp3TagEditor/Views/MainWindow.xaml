<Window x:Class="Mp3TagEditor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Mp3TagEditor.ViewModels"
        xmlns:conv="clr-namespace:Mp3TagEditor.Converters"
        Title="MP3 Tag Editor" Height="800" Width="1280"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        Background="#FF1E1E2E">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
        <conv:BoolToFontWeightConverter x:Key="BoolToWeight" />

        <!-- ダークテーマ共通スタイル -->
        <SolidColorBrush x:Key="BgPrimary" Color="#FF1E1E2E" />
        <SolidColorBrush x:Key="BgSecondary" Color="#FF2A2A3C" />
        <SolidColorBrush x:Key="BgTertiary" Color="#FF363649" />
        <SolidColorBrush x:Key="FgPrimary" Color="#FFCDD6F4" />
        <SolidColorBrush x:Key="FgSecondary" Color="#FFA6ADC8" />
        <SolidColorBrush x:Key="AccentBlue" Color="#FF89B4FA" />
        <SolidColorBrush x:Key="AccentGreen" Color="#FFA6E3A1" />
        <SolidColorBrush x:Key="AccentPeach" Color="#FFFAB387" />
        <SolidColorBrush x:Key="AccentRed" Color="#FFF38BA8" />
        <SolidColorBrush x:Key="BorderColor" Color="#FF45475A" />

        <!-- ボタンスタイル -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BgTertiary}" />
            <Setter Property="Foreground" Value="{StaticResource FgPrimary}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Margin" Value="4,2" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF4A4A5E" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF5A5A6E" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#FF3A3A8C" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF4A4A9C" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF5A5AAC" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- テキストボックススタイル -->
        <Style x:Key="EditTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgTertiary}" />
            <Setter Property="Foreground" Value="{StaticResource FgPrimary}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="CaretBrush" Value="{StaticResource FgPrimary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBlue}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ラベルスタイル -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource FgSecondary}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== ツールバー ===== -->
        <Border Grid.Row="0" Background="{StaticResource BgSecondary}" Padding="8,6"
                BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
            <WrapPanel>
                <Button Content="📂 ファイルを開く" Command="{Binding OpenFilesCommand}"
                        Style="{StaticResource ActionButton}" />
                <Button Content="📁 フォルダを開く" Command="{Binding OpenFolderCommand}"
                        Style="{StaticResource ActionButton}" />
                <Separator Style="{x:Null}" Width="1" Background="{StaticResource BorderColor}"
                           Margin="8,4" />
                <Button Content="🔍 選択ファイルを自動取得" Command="{Binding AutoFetchSelectedCommand}"
                        Style="{StaticResource AccentButton}" />
                <Button Content="🔍 全ファイルを一括取得" Command="{Binding AutoFetchAllCommand}"
                        Style="{StaticResource AccentButton}" />
                <Separator Style="{x:Null}" Width="1" Background="{StaticResource BorderColor}"
                           Margin="8,4" />
                <Button Content="💾 すべて保存" Command="{Binding SaveAllCommand}"
                        Style="{StaticResource ActionButton}" Foreground="{StaticResource AccentGreen}" />
                <Button Content="💾 選択を保存" Command="{Binding SaveSelectedCommand}"
                        Style="{StaticResource ActionButton}" />
                <Separator Style="{x:Null}" Width="1" Background="{StaticResource BorderColor}"
                           Margin="8,4" />
                <Button Content="✅ 全選択" Command="{Binding SelectAllCommand}"
                        Style="{StaticResource ActionButton}" />
                <Button Content="☐ 全解除" Command="{Binding DeselectAllCommand}"
                        Style="{StaticResource ActionButton}" />
                <Button Content="🗑 選択を除去" Command="{Binding RemoveSelectedFilesCommand}"
                        Style="{StaticResource ActionButton}" Foreground="{StaticResource AccentRed}" />
                <Button Content="⏹ キャンセル" Command="{Binding CancelCommand}"
                        Style="{StaticResource ActionButton}"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
            </WrapPanel>
        </Border>

        <!-- ===== メインコンテンツ ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="380" MinWidth="300" />
            </Grid.ColumnDefinitions>

            <!-- 左側: ファイル一覧 -->
            <Border Grid.Column="0" Background="{StaticResource BgPrimary}" Margin="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="ファイル一覧" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource FgPrimary}" Margin="8,8,8,4" />

                    <!-- ファイル一覧DataGrid -->
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Files}"
                              SelectedItem="{Binding SelectedFile}"
                              AutoGenerateColumns="False"
                              SelectionMode="Single"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              Background="{StaticResource BgPrimary}"
                              Foreground="{StaticResource FgPrimary}"
                              BorderThickness="0"
                              RowBackground="{StaticResource BgPrimary}"
                              AlternatingRowBackground="{StaticResource BgSecondary}"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{StaticResource BorderColor}"
                              HeadersVisibility="Column"
                              ColumnHeaderHeight="32"
                              RowHeight="30"
                              FontSize="13">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{StaticResource BgTertiary}" />
                                <Setter Property="Foreground" Value="{StaticResource FgSecondary}" />
                                <Setter Property="Padding" Value="8,4" />
                                <Setter Property="BorderBrush" Value="{StaticResource BorderColor}" />
                                <Setter Property="BorderThickness" Value="0,0,1,1" />
                                <Setter Property="FontSize" Value="12" />
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="8,4" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                <ContentPresenter VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#FF3A3A5C" />
                                        <Setter Property="Foreground" Value="{StaticResource FgPrimary}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="FontWeight"
                                        Value="{Binding IsModified, Converter={StaticResource BoolToWeight}}" />
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#FF3A3A5C" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                     Header="✓" Width="35" IsReadOnly="False" />
                            <DataGridTextColumn Binding="{Binding FileName}" Header="ファイル名" Width="200" />
                            <DataGridTextColumn Binding="{Binding Title}" Header="タイトル" Width="180" />
                            <DataGridTextColumn Binding="{Binding Artist}" Header="アーティスト" Width="150" />
                            <DataGridTextColumn Binding="{Binding Album}" Header="アルバム" Width="180" />
                            <DataGridTextColumn Binding="{Binding TrackNumber}" Header="#" Width="40" />
                            <DataGridTextColumn Binding="{Binding Year}" Header="年" Width="50" />
                            <DataGridTextColumn Binding="{Binding Genre}" Header="ジャンル" Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- ドラッグ&ドロップヒント（ファイルがないとき） -->
                    <TextBlock Grid.Row="1"
                               Text="ここにMP3ファイルまたはフォルダを&#x0a;ドラッグ&amp;ドロップ"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="18" Foreground="{StaticResource FgSecondary}"
                               TextAlignment="Center" Opacity="0.5"
                               Visibility="{Binding Files.Count, Converter={StaticResource NullToVis}, ConverterParameter=invert}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Files.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- スプリッター -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderColor}" />

            <!-- 右側: 編集パネル -->
            <Border Grid.Column="2" Background="{StaticResource BgSecondary}" Margin="4"
                    CornerRadius="8" Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="タグ編集" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource FgPrimary}" Margin="0,0,0,12" />

                        <!-- ファイル未選択時のメッセージ -->
                        <TextBlock Text="ファイルを選択してください"
                                   Foreground="{StaticResource FgSecondary}"
                                   FontSize="14" HorizontalAlignment="Center" Margin="0,40,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSelectedFile}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- 編集フォーム（ファイル選択時のみ表示） -->
                        <StackPanel Visibility="{Binding HasSelectedFile, Converter={StaticResource BoolToVis}}">

                            <!-- カバー画像 -->
                            <Border Background="{StaticResource BgTertiary}" CornerRadius="8"
                                    Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="カバー画像" Style="{StaticResource FieldLabel}" />
                                    <Grid>
                                        <Border Background="#FF181825" CornerRadius="4"
                                                Width="200" Height="200" HorizontalAlignment="Center"
                                                Margin="0,4,0,8">
                                            <Grid>
                                                <TextBlock Text="No Image" Foreground="{StaticResource FgSecondary}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           FontSize="14" />
                                                <Image Source="{Binding SelectedFile.CoverImage}"
                                                       Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" />
                                            </Grid>
                                        </Border>
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="画像を選択" Command="{Binding SetCoverImageCommand}"
                                                Style="{StaticResource ActionButton}" />
                                        <Button Content="画像を削除" Command="{Binding RemoveCoverImageCommand}"
                                                Style="{StaticResource ActionButton}"
                                                Foreground="{StaticResource AccentRed}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- 基本情報 -->
                            <Border Background="{StaticResource BgTertiary}" CornerRadius="8"
                                    Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="タイトル" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding SelectedFile.Title, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource EditTextBox}" Margin="0,0,0,8" />

                                    <TextBlock Text="アーティスト" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding SelectedFile.Artist, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource EditTextBox}" Margin="0,0,0,8" />

                                    <TextBlock Text="アルバム" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding SelectedFile.Album, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource EditTextBox}" Margin="0,0,0,8" />

                                    <TextBlock Text="アルバムアーティスト" Style="{StaticResource FieldLabel}" />
                                    <TextBox Text="{Binding SelectedFile.AlbumArtist, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource EditTextBox}" Margin="0,0,0,8" />

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="トラック#" Style="{StaticResource FieldLabel}" />
                                            <TextBox Text="{Binding SelectedFile.TrackNumber, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource EditTextBox}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="年" Style="{StaticResource FieldLabel}" />
                                            <TextBox Text="{Binding SelectedFile.Year, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource EditTextBox}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="ジャンル" Style="{StaticResource FieldLabel}" />
                                            <TextBox Text="{Binding SelectedFile.Genre, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource EditTextBox}" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 手動検索 -->
                            <Border Background="{StaticResource BgTertiary}" CornerRadius="8"
                                    Padding="12" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="手動検索（iTunes）" Style="{StaticResource FieldLabel}"
                                               FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8" />
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="SearchBox" Grid.Column="0"
                                                 Style="{StaticResource EditTextBox}"
                                                 Margin="0,0,8,0"
                                                 KeyDown="SearchBox_KeyDown" />
                                        <Button Grid.Column="1" Content="検索"
                                                Style="{StaticResource AccentButton}"
                                                Click="SearchButton_Click" />
                                    </Grid>

                                    <!-- 検索結果リスト -->
                                    <ListBox ItemsSource="{Binding SearchResults}"
                                             SelectedItem="{Binding SelectedSearchResult}"
                                             MaxHeight="200"
                                             Background="{StaticResource BgPrimary}"
                                             Foreground="{StaticResource FgPrimary}"
                                             BorderBrush="{StaticResource BorderColor}"
                                             BorderThickness="1"
                                             Margin="0,0,0,8"
                                             Visibility="{Binding SearchResults.Count, Converter={StaticResource NullToVis}}">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="8,6" />
                                                <Setter Property="Foreground" Value="{StaticResource FgPrimary}" />
                                                <Setter Property="Background" Value="Transparent" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="#FF3A3A5C" />
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource BgTertiary}" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold" FontSize="13">
                                                        <Run Text="{Binding TrackName}" />
                                                    </TextBlock>
                                                    <TextBlock FontSize="11" Foreground="{StaticResource FgSecondary}">
                                                        <Run Text="{Binding ArtistName}" />
                                                        <Run Text=" / " />
                                                        <Run Text="{Binding CollectionName}" />
                                                    </TextBlock>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <Button Content="選択した結果を適用"
                                            Command="{Binding ApplySearchResultCommand}"
                                            Style="{StaticResource AccentButton}"
                                            HorizontalAlignment="Stretch" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ===== ステータスバー ===== -->
        <Border Grid.Row="2" Background="{StaticResource BgSecondary}" Padding="12,6"
                BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource FgSecondary}"
                               FontSize="12" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding ProgressText}" Foreground="{StaticResource AccentBlue}"
                               FontSize="12" Margin="16,0,0,0" VerticalAlignment="Center" />
                </StackPanel>

                <ProgressBar Grid.Column="1" Width="200" Height="14"
                             Value="{Binding ProgressValue}" Maximum="{Binding ProgressMax}"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                             Background="{StaticResource BgTertiary}"
                             Foreground="{StaticResource AccentBlue}"
                             BorderThickness="0" />
            </Grid>
        </Border>
    </Grid>
</Window>
